{
  "expo": {
    "name": "CineGate",
    "slug": "cinegate",
    "icon": "./assets/icons/CUY.png",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icons/vidiconn.png",
      "name": "CineGate",
      "shortName": "CineGate",
      "display": "standalone",
      "themeColor": "#024A59",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos",
          "cameraPermission": "The app accesses your camera to let you take photos of your documents."
        }
      ],
      "expo-font",
      "expo-asset"
    ]
  }
}
